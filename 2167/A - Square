#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(0);
    cin.tie(0);
 
    int t, a, b, confirm;
 
    cin >> t;
 
    for (int i = 0; i < t; i++) {
        confirm = 1;
        cin >> a;
 
        for (int j = 0; j < 3; j++) {
            cin >> b;
            if (a != b) {
                confirm = 0;
            }
        }
        if (confirm) {
            cout << "YES
";
        }
        else {
            cout << "NO
";
        }
    }
 
    return 0;
}